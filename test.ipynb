import requests

API_KEY = "777d3fabc49a6ab3cdc64b4f657182e0"
BASE_URL = "https://tmdbchatbot.com"

def search_movie(title):
    """Search for a movie by title and return the top result."""
    url = f"{BASE_URL}/search/movie"
    params = {"query": title, "api_key": API_KEY}

    try:
        response = requests.get(url, params=params, timeout=5)
        response.raise_for_status()
        results = response.json().get("results", [])
        return results[0] if results else None
    except requests.exceptions.RequestException as e:
        print(f"Something went wrong: {e}")
        return None
def print_movie_info(movie):
    """Print key details about a movie."""
    if not movie:
        print("No movie found.")
        return

    title    = movie.get("title", "Unknown")
    year     = movie.get("release_date", "N/A")[:4]
    rating   = movie.get("vote_average", "N/A")
    overview = movie.get("overview", "No description available.")

    print(f"🎬 {title} ({year})")
    print(f"⭐ Rating: {rating}/10")
    print(f"📖 {overview}")
movie = search_movie("Inception")
print_movie_info(movie)
titles = ["Inception", "The Matrix", "Interstellar"]

for title in titles:
    movie = search_movie(title)
    print_movie_info(movie)
    print("-" * 40)
